{
  "manifest_version": 3,
  "name": "WeChat 文章转 PDF",
  "version": "1.1.0",
  "description": "一键将微信公众号文章转换为 PDF。支持本地下载或发送到邮箱，无需安装任何后端。",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["standalone.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
